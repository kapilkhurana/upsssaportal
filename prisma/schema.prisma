generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                   @id @default(cuid())
  username            String                   @unique
  passwordHash        String
  name                String?
  role                String
  districtCode        String?
  verifierCapacity    Int?
  active              Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  preferredLocale       String?
  appealDecisions     Appeal[]                 @relation("AppealDecider")
  auditLogs           AuditLog[]               @relation("AuditLogActor")
  uploadedEvidence    EvidenceAsset[]          @relation("UploadedEvidence")
  verifications       VerificationSubmission[]
  verifierAssignments VerifierAssignment[]
  verifierDistricts   VerifierDistrict[]       @relation("VerifierDistricts")
  notifications       Notification[]
  notificationPreference NotificationPreference?
}

model District {
  id      String   @id @default(cuid())
  code    String   @unique
  nameEn  String
  nameHi  String
  blocks  Block[]
  schools School[]
}

model Block {
  id           String   @id @default(cuid())
  code         String   @unique
  districtCode String
  nameEn       String
  nameHi       String
  district     District @relation(fields: [districtCode], references: [code])
  schools      School[]
}

model School {
  id                  String                     @id @default(cuid())
  udise               String                     @unique
  nameEn              String
  nameHi              String
  category            String
  districtCode        String
  blockCode           String
  addressEn           String?
  addressHi           String?
  publicPhone         String?
  feesRangeMin        Int?
  feesRangeMax        Int?
  nameSynthetic       Boolean                    @default(false)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([districtCode])
  @@index([blockCode])
  @@index([nameEn])
  @@index([category])
  appeals             Appeal[]
  ratings             ParentRating[]
  results             Result[]
  block               Block                      @relation(fields: [blockCode], references: [code])
  district            District                   @relation(fields: [districtCode], references: [code])
  selfAssessments     SelfAssessmentSubmission[]
  tickets             Ticket[]
  verifications       VerificationSubmission[]
  verifierAssignments VerifierAssignment[]
  feeDisclosure       FeeDisclosure?
  schoolScholarships  SchoolScholarship[]
  mandatoryDocuments  MandatoryDocument[]
}

model DisputeCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  nameEn    String
  nameHi    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]
}

model Ticket {
  id              String           @id @default(cuid())
  schoolUdise     String
  categoryCode    String
  districtCode    String           @default("")
  description     String
  submitterName   String?
  submitterMobile String
  status          String           @default("ASSIGNED_TO_SCHOOL")
  handlerLevel    String           @default("SCHOOL")
  schoolArgument  String?
  verifierResponse String?
  nextDueAt       DateTime?
  lastEscalatedAt DateTime?
  resolvedAt      DateTime?
  rejectedAt      DateTime?
  closedReason    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        DisputeCategory  @relation(fields: [categoryCode], references: [code])
  school          School           @relation(fields: [schoolUdise], references: [udise])
  timeline        TicketTimeline[]
  disputeHistory  DisputeHistory[]
}

model DisputeHistory {
  id         String   @id @default(cuid())
  ticketId   String
  actorUserId String?
  actionType String
  notes      String?
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketTimeline {
  id        String   @id @default(cuid())
  ticketId  String
  actorType String
  actorRole String?
  eventType String   @default("NOTE")
  message   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Cycle {
  id                  String                     @id @default(cuid())
  name                String                     @unique
  isActive            Boolean                    @default(false)
  startsAt            DateTime?
  endsAt              DateTime?
  resultsPublished    Boolean                    @default(false)
  resultsPublishedAt  DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  appeals             Appeal[]
  frameworks          Framework?
  ratings             ParentRating[]
  results             Result[]
  selfAssessments     SelfAssessmentSubmission[]
  verifications       VerificationSubmission[]
  verifierAssignments VerifierAssignment[]
}

model Framework {
  id              String                     @id @default(cuid())
  cycleId         String                     @unique
  status          String                     @default("DRAFT")
  version         Int                        @default(1)
  publishedAt     DateTime?
  publishedBy     String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  appeals         Appeal[]
  cycle           Cycle                      @relation(fields: [cycleId], references: [id])
  levels          FrameworkLevel[]
  gradeBands      GradeBand[]
  parameters      Parameter[]
  results         Result[]
  rubricMappings  RubricMapping[]
  selfAssessments SelfAssessmentSubmission[]
  domains         SqaafDomain[]
  subDomains      SubDomain[]
  verifications   VerificationSubmission[]
}

model SqaafDomain {
  id            String      @id @default(cuid())
  frameworkId   String
  code          String
  titleEn       String
  titleHi       String
  order         Int
  weightPercent Float?
  isActive      Boolean     @default(true)
  framework     Framework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  subDomains    SubDomain[]

  @@unique([frameworkId, code])
  @@unique([frameworkId, order])
}

model SubDomain {
  id          String      @id @default(cuid())
  frameworkId String
  domainId    String
  code        String
  titleEn     String
  titleHi     String
  order       Int
  isActive    Boolean     @default(true)
  parameters  Parameter[]
  domain      SqaafDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  framework   Framework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, code])
  @@unique([domainId, order])
}

model Parameter {
  id                String                   @id @default(cuid())
  frameworkId       String
  subDomainId       String
  code              String
  titleEn           String
  titleHi           String
  order             Int
  applicability     Json
  inputType         String                   @default("SINGLE_SELECT")
  evidenceRequired  Boolean                  @default(false)
  dataSources       Json                     @default("[\"Manual\"]")
  isActive          Boolean                  @default(true)
  appealItems       AppealItem[]
  evidenceLinks     EvidenceLink[]           @relation("ParamEvidence")
  framework         Framework                @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  subDomain         SubDomain                @relation(fields: [subDomainId], references: [id], onDelete: Cascade)
  options           ParameterOption[]
  rubricMappings    RubricMapping[]
  saResponses       SelfAssessmentResponse[]
  verifierResponses VerificationResponse[]

  @@unique([frameworkId, code])
  @@unique([subDomainId, order])
}

model ParameterOption {
  id          String    @id @default(cuid())
  parameterId String
  key         String
  labelEn     String
  labelHi     String
  order       Int
  isActive    Boolean   @default(true)
  parameter   Parameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([parameterId, key])
}

model RubricMapping {
  id          String    @id @default(cuid())
  frameworkId String
  parameterId String
  optionKey   String
  score       Int
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  parameter   Parameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, parameterId, optionKey])
}

model FrameworkLevel {
  id          String    @id @default(cuid())
  frameworkId String
  key         String
  labelEn     String
  labelHi     String
  order       Int
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, key])
}

model GradeBand {
  id          String    @id @default(cuid())
  frameworkId String
  key         String
  labelEn     String
  labelHi     String
  minPercent  Float
  maxPercent  Float
  order       Int
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, key])
}

model SelfAssessmentSubmission {
  id            String                   @id @default(cuid())
  cycleId       String
  schoolUdise   String
  frameworkId   String
  status        String                   @default("DRAFT")
  startedAt     DateTime?
  submittedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  evidenceLinks EvidenceLink[]           @relation("SAEvidence")
  responses     SelfAssessmentResponse[]
  cycle         Cycle                    @relation(fields: [cycleId], references: [id])
  framework     Framework                @relation(fields: [frameworkId], references: [id])
  school        School                   @relation(fields: [schoolUdise], references: [udise])

  @@unique([cycleId, schoolUdise])
}

model SelfAssessmentResponse {
  id                String                   @id @default(cuid())
  submissionId      String
  parameterId       String
  selectedOptionKey String
  notes             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  parameter         Parameter                @relation(fields: [parameterId], references: [id])
  submission        SelfAssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, parameterId])
}

model VerifierAssignment {
  id             String                  @id @default(cuid())
  cycleId        String
  schoolUdise    String
  verifierUserId String
  deadlineAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  submission     VerificationSubmission?
  cycle          Cycle                   @relation(fields: [cycleId], references: [id])
  school         School                  @relation(fields: [schoolUdise], references: [udise])
  verifier       User                    @relation(fields: [verifierUserId], references: [id])

  @@unique([cycleId, schoolUdise])
}

model VerificationSubmission {
  id             String                 @id @default(cuid())
  cycleId        String
  schoolUdise    String
  frameworkId    String
  assignmentId   String                 @unique
  verifierUserId String
  status         String                 @default("DRAFT")
  startedAt      DateTime?
  submittedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  evidenceLinks  EvidenceLink[]         @relation("VEvidence")
  responses      VerificationResponse[]
  assignment     VerifierAssignment     @relation(fields: [assignmentId], references: [id])
  cycle          Cycle                  @relation(fields: [cycleId], references: [id])
  framework      Framework              @relation(fields: [frameworkId], references: [id])
  school         School                 @relation(fields: [schoolUdise], references: [udise])
  verifier       User                   @relation(fields: [verifierUserId], references: [id])
}

model VerificationResponse {
  id                String                 @id @default(cuid())
  submissionId      String
  parameterId       String
  selectedOptionKey String
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  parameter         Parameter              @relation(fields: [parameterId], references: [id])
  submission        VerificationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, parameterId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation("AuditLogActor", fields: [actorUserId], references: [id])
}

model VerifierDistrict {
  id             String @id @default(cuid())
  verifierUserId String
  districtCode   String
  verifier       User   @relation("VerifierDistricts", fields: [verifierUserId], references: [id], onDelete: Cascade)

  @@unique([verifierUserId, districtCode])
}

model Appeal {
  id              String       @id @default(cuid())
  cycleId         String
  schoolUdise     String
  frameworkId     String
  status          String       @default("DRAFT")
  submittedAt     DateTime?
  decidedAt       DateTime?
  decidedByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cycle           Cycle        @relation(fields: [cycleId], references: [id])
  decidedBy       User?        @relation("AppealDecider", fields: [decidedByUserId], references: [id])
  framework       Framework    @relation(fields: [frameworkId], references: [id])
  school          School       @relation(fields: [schoolUdise], references: [udise])
  items           AppealItem[]

  @@unique([cycleId, schoolUdise])
}

model AppealItem {
  id                        String         @id @default(cuid())
  appealId                  String
  parameterId               String
  schoolSelectedOptionKey   String
  verifierSelectedOptionKey String
  schoolJustification       String?
  decision                  String         @default("PENDING")
  decidedAt                 DateTime?
  appeal                    Appeal         @relation(fields: [appealId], references: [id], onDelete: Cascade)
  parameter                 Parameter      @relation(fields: [parameterId], references: [id])
  evidenceLinks             EvidenceLink[] @relation("AppealItemEvidence")

  @@unique([appealId, parameterId])
}

model Result {
  id                   String    @id @default(cuid())
  cycleId              String
  schoolUdise          String
  frameworkId          String
  selfScorePercent     Float?
  verifierScorePercent Float?
  finalScorePercent    Float?
  gradeBandCode        String?
  publishedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  cycle                Cycle     @relation(fields: [cycleId], references: [id])
  framework            Framework @relation(fields: [frameworkId], references: [id])
  school               School    @relation(fields: [schoolUdise], references: [udise])

  @@unique([cycleId, schoolUdise])
}

model EvidenceAsset {
  id               String        @id @default(cuid())
  blobUrl          String
  fileName         String
  fileType         String
  fileSize         Int
  uploadedByUserId String
  createdAt        DateTime      @default(now())
  uploadedBy       User          @relation("UploadedEvidence", fields: [uploadedByUserId], references: [id])
  links            EvidenceLink?
}

model EvidenceLink {
  id             String                    @id @default(cuid())
  assetId        String                    @unique
  kind           String
  saSubmissionId String?
  vSubmissionId  String?
  parameterId    String?
  appealItemId   String?
  appealItem     AppealItem?               @relation("AppealItemEvidence", fields: [appealItemId], references: [id])
  asset          EvidenceAsset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  parameter      Parameter?                @relation("ParamEvidence", fields: [parameterId], references: [id])
  saSubmission   SelfAssessmentSubmission? @relation("SAEvidence", fields: [saSubmissionId], references: [id])
  vSubmission    VerificationSubmission?   @relation("VEvidence", fields: [vSubmissionId], references: [id])
}

model RatingDimension {
  id        String   @id @default(cuid())
  code      String   @unique
  labelEn   String
  labelHi   String
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentRating {
  id              String   @id @default(cuid())
  cycleId         String
  schoolUdise     String
  submitterMobile String
  ratingsJson     Json
  comment         String?
  createdAt       DateTime @default(now())
  cycle           Cycle    @relation(fields: [cycleId], references: [id])
  school          School   @relation(fields: [schoolUdise], references: [udise])

  @@unique([cycleId, schoolUdise, submitterMobile])
}

enum ScholarshipScheme {
  MERIT
  EWS
  SPORTS
  SC_ST
  MINORITY
  DIFFERENTLY_ABLED
}

enum MandatoryDocumentStatus {
  NOT_UPLOADED
  UPLOADED
  EXPIRED
  ACKNOWLEDGED
}

enum NotificationType {
  CYCLE_OPENED
  SUBMISSION_RECEIVED
  REVIEW_COMMENT
  DEADLINE_REMINDER
  DISPUTE_FILED
}

model FeeDisclosure {
  id                  String   @id @default(cuid())
  schoolUdise         String   @unique
  annualTuition       Int      @default(0)
  admissionFee        Int      @default(0)
  transportFee        Int      @default(0)
  otherCharges        Int      @default(0)
  scholarshipsSummary String?
  lastUpdated         DateTime @default(now())
  school              School   @relation(fields: [schoolUdise], references: [udise], onDelete: Cascade)
}

model SchoolScholarship {
  id          String            @id @default(cuid())
  schoolUdise String
  scheme      ScholarshipScheme
  available   Boolean           @default(false)
  school      School            @relation(fields: [schoolUdise], references: [udise], onDelete: Cascade)

  @@unique([schoolUdise, scheme])
}

model MandatoryDocument {
  id           String                  @id @default(cuid())
  schoolUdise  String
  documentType String
  fileUrl      String?
  validTill    DateTime?
  uploadedAt   DateTime?
  status       MandatoryDocumentStatus @default(NOT_UPLOADED)
  school       School                  @relation(fields: [schoolUdise], references: [udise], onDelete: Cascade)

  @@unique([schoolUdise, documentType])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id             String  @id @default(cuid())
  userId         String  @unique
  emailAlerts    Boolean @default(true)
  smsAlerts      Boolean @default(false)
  disputeAlerts  Boolean @default(true)
  cycleReminders Boolean @default(true)
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
